{
  "name": "app",
  "version": "0.1.0",
  "description": "Private payments app on Stellar",
  "main": "js/app.js",
  "scripts": {
    "build:css": "tailwindcss -i css/tailwind.src.css -o css/app.css",
    "dev:css": "tailwindcss -i css/tailwind.src.css -o css/app.css --watch",
    "sync:dev-artifacts": "bash ../scripts/sync-app-dev-artifacts.sh",
    "predev": "npm run sync:dev-artifacts",
    "dev": "python3 -m http.server 8080",
    "test": "jest",
    "test:e2e": "playwright test --config e2e/playwright.config.js",
    "test:e2e:headed": "playwright test --config e2e/playwright.config.js --headed",
    "test:e2e:download-extension": "node e2e/helpers/download-extension.js"
  },
  "author": "",
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.4",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/cli": "^4.2.2",
    "babel-jest": "^29.7.0",
    "esbuild": "^0.27.2",
    "fake-indexeddb": "^6.2.5",
    "jest": "^29.7.0",
    "serve": "^14.2.0",
    "tailwindcss": "^4.1.18"
  },
  "dependencies": {
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^14.4.2",
    "bignumber.js": "^9.3.1",
    "jszip": "^3.10.1"
  }
}
