    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch --no-coverage"
  },
  "dependencies": {
    "@enclave/core": "*",
    "@noble/hashes": "^2.0.1",
    "@stellar/stellar-sdk": "14.4.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "jest": "29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "5.6.3"
  }
}
