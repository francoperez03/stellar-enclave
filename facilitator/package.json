{
  "name": "@enclave/facilitator",
  "version": "0.0.0",
  "private": true,
  "description": "Enclave facilitator HTTP service — shielded proof -> public USDC x402 bridge (Phase 2).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --project unit --project integration",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@enclave/core": "*",
    "@stellar/stellar-sdk": "14.4.2",
    "@x402/core": "2.6.0",
    "@x402/stellar": "2.6.0",
    "@noble/hashes": "^2.0.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "cors": "^2.8.6",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "dotenv": "^16.6.1",
    "proxy-addr": "^2.0.7",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vitest": "^3.2.4",
    "supertest": "^7.2.2",
    "pino-pretty": "^13.1.3",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/supertest": "^6.0.2",
    "@types/node": "22.9.0"
  }
}
