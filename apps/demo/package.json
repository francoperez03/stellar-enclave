{
  "name": "@enclave/demo",
  "version": "0.0.0",
  "private": true,
  "description": "Enclave demo app with gated endpoint — Northfield Capital only (Phase 4).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@enclave/core": "*",
    "@enclave/gate": "*",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "cors": "^2.8.6",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "vitest": "^3.2.4",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "pino-pretty": "^13.1.3",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/supertest": "^6.0.2",
    "@types/node": "22.9.0"
  }
}
