# Landing page env vars (all NEXT_PUBLIC_* so they inline into the client bundle).
# Set in Vercel dashboard for production.

# "Go to App" CTA destination (where the console is hosted).
# Fallback if unset: /enclave.html (same-origin).
NEXT_PUBLIC_CONSOLE_URL=https://enclave-console.vercel.app/enclave.html

# 11-char YouTube video ID for the 3-min demo. Leave empty to hide the "Watch the demo" CTA.
# Populated after Phase 6 publishes the video.
NEXT_PUBLIC_YOUTUBE_VIDEO_ID=

# Footer links — populated at submission time.
NEXT_PUBLIC_GITHUB_URL=https://github.com/francoperez03/stellar-enclave
NEXT_PUBLIC_DORAHACKS_URL=
